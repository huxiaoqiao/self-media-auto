# OpenAI 格式大模型调用 (可替换成 DeepSeek/Qwen 等兼容地址)
OPENAI_API_KEY=sk-your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# AI 图片生成偏好模型 (可使用 gpt-image-1.5 等)
OPENAI_IMAGE_MODEL=gpt-image-1.5

# 公众号发文使用
# 前往开发者后台：我的业务 → 公众号 → 开发密钥 获取
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# 阿里云百炼 API KEY (生图使用)
DASHSCOPE_API_KEY=your_dashscope_api_key

# 大模型 ID (如 deepseek-chat, qwen-max 等)
LLM_MODEL_ID=deepseek-chat

# 硅基流动 API Key (用于视频语音转文字)
SILI_FLOW_API_KEY=your_siliflow_api_key

# 其他如火山、阿里云等 API（如使用其图片服务）
# JIMENG_ACCESS_KEY_ID=
# JIMENG_SECRET_ACCESS_KEY=

# OpenClaw/Telegram 推送
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 次幂数据 API
CIMI_APP_ID=your_cimi_app_id
CIMI_APP_SECRET=your_cimi_app_secret

# 爆款文章 API Provider 选择 (jizhile | cimi)
HOT_ARTICLE_PROVIDER=jizhile

# 极致了 API 配置
JIZHILE_KEY=your_jizhile_key
JIZHILE_CATEGORY=7  # 7=科技（默认），完整分类见 docs/hot_typical_search.md
JIZHILE_KEYWORD=OpenClaw  # 搜索关键词

# 次幂分类独立配置
CIMI_CATEGORY=keji  # 次幂分类，独立于极致了

# Firecrawl API (用于深度网页和公众号文章抓取，可选)
FIRECRAWL_API_KEY=your_firecrawl_api_key

# Tavily WebSearch API (用于实时网络搜索增强，可选)
TAVILY_API_KEY=your_tavily_api_key

# ===============
# 创作 IP 设定
# ===============
AUTHOR_IP_NAME="大胡"

# ===============
# 视频脚本生成控制
# ===============
# 是否生成短视频脚本 (true/false, 默认：true)
# 设置为 false 可跳过视频脚本生成，节省 API 调用和时间
GENERATE_VIDEO_SCRIPT=true
